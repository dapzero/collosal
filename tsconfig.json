{
  "compilerOptions": {
    "target": "es2020", // <- default "es5"
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // <- default "node"
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {              // <- default "baseUrl": "./"
      "@/*": ["./"]  
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
//    "try.js"              // <- default memakai "try.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
